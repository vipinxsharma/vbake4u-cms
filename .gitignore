############################
# VBake4U CMS .gitignore   #
############################

# Build output
dist
.cache
build

# Strapi generated files
.tmp
.strapi-updater.json
.strapi/

# Local uploads (use R2 in production)
public/uploads

# Environment — NEVER commit real secrets
.env
.env.*
!.env.example

# Dependencies
node_modules
package-lock.json

# OS artifacts
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo

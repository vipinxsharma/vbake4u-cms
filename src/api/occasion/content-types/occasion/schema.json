{
  "kind": "collectionType",
  "collectionName": "occasions",
  "info": {
    "singularName": "occasion",
    "pluralName": "occasions",
    "displayName": "Occasion",
    "description": "SEO landing pages: Birthday, Wedding, Anniversary, Baby Shower, Festival, Corporate"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "heroPhoto": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "intro": {
      "type": "richtext",
      "description": "80–120 word intro paragraph for SEO — appears above the cake grid"
    },
    "featuredCakes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::cake.cake",
      "inversedBy": "occasions"
    },
    "featuredCombos": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::combo.combo",
      "inversedBy": "occasions"
    },
    "seoTitle": {
      "type": "string",
      "description": "e.g. 'Birthday Cakes in Pune | VBake4U'"
    },
    "seoDescription": {
      "type": "text"
    },
    "seoOgImage": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "isActive": {
      "type": "boolean",
      "default": true,
      "required": true
    }
  }
}

{
  "kind": "collectionType",
  "collectionName": "combos",
  "info": {
    "singularName": "combo",
    "pluralName": "combos",
    "displayName": "Combo",
    "description": "Bundle deals: one cake + add-ons at a discounted bundlePrice"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "includedCake": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::cake.cake"
    },
    "includedAddOns": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::add-on.add-on"
    },
    "bundlePrice": {
      "type": "decimal",
      "required": true
    },
    "savingsLabel": {
      "type": "string",
      "description": "e.g. 'Save ₹200' — shown on the combo card"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "occasions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::occasion.occasion",
      "mappedBy": "featuredCombos"
    },
    "isActive": {
      "type": "boolean",
      "default": true,
      "required": true
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    }
  }
}

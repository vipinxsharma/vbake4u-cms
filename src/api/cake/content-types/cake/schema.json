{
  "kind": "collectionType",
  "collectionName": "cakes",
  "info": {
    "singularName": "cake",
    "pluralName": "cakes",
    "displayName": "Cake",
    "description": "VBake4U cake catalog — standard and custom cakes"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "cakes"
    },
    "description": {
      "type": "richtext"
    },
    "shortDescription": {
      "type": "text",
      "description": "One-liner for catalog cards (max ~100 chars)"
    },
    "gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "basePrice": {
      "type": "decimal",
      "description": "Base price in INR for the smallest/default weight option"
    },
    "startingPriceLabel": {
      "type": "string",
      "description": "Display label e.g. 'From ₹1,299'. Overrides auto-format when set."
    },
    "availableWeights": {
      "type": "json",
      "description": "JSON array of weight options displayed as chips on the product page. Use plain strings. Example: [\"0.5 kg\", \"1 kg\", \"1.5 kg\", \"2 kg\"]. Leave blank if only one size is available."
    },
    "availableFlavors": {
      "type": "json",
      "description": "JSON array of flavour options displayed as chips on the product page. Example: [\"Chocolate\", \"Vanilla\", \"Strawberry\", \"Red Velvet\"]. Leave blank if the cake is available in one flavour only."
    },
    "egglessAvailable": {
      "type": "boolean",
      "default": false,
      "required": true
    },
    "allergenInfo": {
      "type": "text",
      "description": "Short, plain-English allergen note shown on the product page. Example: \"Contains: wheat, eggs, dairy. May contain traces of nuts and soy.\" Leave blank if covered by the site-wide allergen policy."
    },
    "leadTimeHours": {
      "type": "integer",
      "default": 24
    },
    "isCustomPricing": {
      "type": "boolean",
      "default": false
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "isActive": {
      "type": "boolean",
      "default": true,
      "required": true
    },
    "addOns": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::add-on.add-on",
      "inversedBy": "cakes"
    },
    "recommendedAddOns": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::add-on.add-on",
      "inversedBy": "recommendedCakes"
    },
    "occasions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::occasion.occasion",
      "mappedBy": "featuredCakes"
    },
    "seoTitle": {
      "type": "string"
    },
    "seoDescription": {
      "type": "text"
    }
  }
}

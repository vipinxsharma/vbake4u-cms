{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order",
    "description": "Cake reservations. Public role: create-only (no public find/findOne)."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "orderNumber": {
      "type": "string",
      "unique": true,
      "description": "Auto-generated by lifecycle: VB-YYYYMMDD-XXXX"
    },
    "customerName": {
      "type": "string",
      "required": true
    },
    "customerPhone": {
      "type": "string",
      "required": true
    },
    "customerEmail": {
      "type": "email"
    },
    "deliveryPincode": {
      "type": "string",
      "required": true
    },
    "deliveryAddress": {
      "type": "text",
      "required": true
    },
    "recipientName": {
      "type": "string",
      "description": "Recipient name if different from customer (gifting)"
    },
    "recipientPhone": {
      "type": "string"
    },
    "deliveryDate": {
      "type": "date",
      "required": true
    },
    "deliveryTimeSlot": {
      "type": "string",
      "description": "Preferred time window, e.g. '10:00-14:00'"
    },
    "cake": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::cake.cake"
    },
    "cakeName": {
      "type": "string",
      "description": "Snapshot of cake name at order time (survives cake rename/delete)"
    },
    "weight": {
      "type": "string",
      "description": "Selected weight, e.g. '1kg'"
    },
    "flavor": {
      "type": "string"
    },
    "eggless": {
      "type": "boolean",
      "default": false
    },
    "messageOnCake": {
      "type": "string",
      "description": "Max ~30 chars to write on cake"
    },
    "addOns": {
      "type": "json",
      "description": "Snapshot of selected add-ons: [{name, price}, ...]"
    },
    "notes": {
      "type": "text",
      "description": "Customer notes for Nitu"
    },
    "orderType": {
      "type": "enumeration",
      "enum": ["standard", "custom"],
      "default": "standard",
      "required": true
    },
    "basePrice": {
      "type": "decimal"
    },
    "addOnsPrice": {
      "type": "decimal",
      "default": 0
    },
    "deliveryFee": {
      "type": "decimal",
      "default": 0
    },
    "totalAmount": {
      "type": "decimal"
    },
    "depositAmount": {
      "type": "decimal"
    },
    "balanceAmount": {
      "type": "decimal"
    },
    "paymentMode": {
      "type": "enumeration",
      "enum": ["deposit", "full", "manual"],
      "default": "deposit",
      "required": true
    },
    "razorpayOrderId": {
      "type": "string"
    },
    "razorpayPaymentId": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending_payment",
        "reserved",
        "confirmed",
        "in_progress",
        "out_for_delivery",
        "completed",
        "cancelled"
      ],
      "default": "pending_payment",
      "required": true
    },
    "whatsappMessageUrl": {
      "type": "string",
      "description": "Pre-filled wa.me URL shown on confirmation page"
    }
  }
}

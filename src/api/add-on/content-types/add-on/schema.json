{
  "kind": "collectionType",
  "collectionName": "add_ons",
  "info": {
    "singularName": "add-on",
    "pluralName": "add-ons",
    "displayName": "Add-On",
    "description": "Candles, Greeting Cards, Cake Toppers, Flowers — optional upsells on PDP"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "isActive": {
      "type": "boolean",
      "default": true,
      "required": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "cakes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::cake.cake",
      "mappedBy": "addOns"
    }
  }
}

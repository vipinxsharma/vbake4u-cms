# ─────────────────────────────────────────────────────────
#  VBake4U CMS — environment variable template
#  Copy to .env, fill in real values. NEVER commit .env
# ─────────────────────────────────────────────────────────

# ── Strapi core secrets ──────────────────────────────────
# Generate each with: openssl rand -base64 32
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=changeme
ADMIN_JWT_SECRET=changeme
JWT_SECRET=changeme
TRANSFER_TOKEN_SALT=changeme
ENCRYPTION_KEY=changeme

# ── Database (PostgreSQL on Railway) ─────────────────────
DATABASE_CLIENT=postgres
# Preferred: single connection string (Railway provides this automatically)
DATABASE_URL=postgresql://strapi:strapi@localhost:5432/vbake4u
# Individual fields used if DATABASE_URL is not set
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=vbake4u
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=strapi
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Server ───────────────────────────────────────────────
HOST=0.0.0.0
PORT=1337
NODE_ENV=development

# ── CORS ─────────────────────────────────────────────────
# Production apex (vbake4u.com) is always in the allow-list.
# Add Vercel preview hashes here to avoid a CMS redeploy per preview.
CORS_EXTRA_ORIGINS=

# ── Cloudflare R2 (media storage) ────────────────────────
# Set STRAPI_PRODUCTION_FORCE_R2=true on Railway to require R2 in production.
# Leave unset in local dev to fall back to disk storage.
STRAPI_PRODUCTION_FORCE_R2=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_BUCKET=vbake4u-media
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://media.vbake4u.com

# ── Resend (transactional email) ─────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=orders@vbake4u.com
# Nitu's notification inbox — receives every new order/quote
EMAIL_TO=nitu@vbake4u.com

# ── Razorpay (payments) ───────────────────────────────────
# Use test keys until Nitu gives go-live approval.
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
# Deposit percentage (0–100). 30 = customer pays 30% upfront to reserve.
RAZORPAY_DEPOSIT_PERCENT=30

# ── OpenAI (AI Cake Maker — Sprint 2) ────────────────────
# Leave blank until Sprint 2 AI features are deployed.
OPENAI_API_KEY=
OPENAI_ORG_ID=

# ── Frontend URL ─────────────────────────────────────────
FRONTEND_URL=http://localhost:3001
